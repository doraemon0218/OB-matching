# ===========================================
# 実行委員管理画面（/admin）のログイン
# ===========================================
#
# 【仕様書・プロトタイプ】
#   ID: admin
#   パスワード: 50th
#
# 【ローカル npm run dev】
#   ADMIN_USER 未設定 → 既定で admin
#   ADMIN_PASSWORD 未設定 → 既定で 50th（プロトタイプと同じ）
#   ADMIN_SESSION_SECRET 未設定 → 開発用の固定値（本番では使わない）
#
# 【Vercel / 本番】
#   次の 2 つは必須（未設定だとログイン API がエラーになります）。
#   - ADMIN_PASSWORD（プロトタイプの 50th は使わず、独自の強いパスワードを設定）
#   - ADMIN_SESSION_SECRET（16文字以上のランダム文字列）
#   ADMIN_USER は省略可（省略時は admin）

ADMIN_USER=admin
ADMIN_PASSWORD=change-me-strong-password
ADMIN_SESSION_SECRET=random-string-at-least-16-chars

# ===========================================
# Supabase（本番推奨）
# ===========================================
# 未設定の場合: ローカルは data/local-db.json、Vercel は /tmp（制約あり）

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
