# --- Supabase 未設定の場合 ---
# ローカル: data/local-db.json
# Vercel: /tmp に一時保存（インスタンス間で共有されないため本番は必ず Supabase を推奨）

# Supabase（任意。設定するとクラウド DB に切り替わります）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 管理画面（本番は必ず設定）
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-long-random-secret

# 開発時（npm run dev）のみ: 上記2つが未設定なら パスワード 50th・固定の開発用シークレットが使われます。
